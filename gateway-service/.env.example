# gateway-service/.env.example
# ─────────────────────────────────────────────────────────────────────────────
# SAFE TO COMMIT — contains no real secrets. Copy this file to .env and fill
# in the actual values for your environment. The .env file is gitignored.
#
#   cp .env.example .env    (Linux / macOS)
#   copy .env.example .env  (Windows PowerShell)
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string for Prisma.
#
# On-Premise (Enterprise Intranet):
#   Replace <DB_HOST_IP> with the actual intranet IP of your PostgreSQL server.
#   DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST_IP>:5432/gateway_db"
#
# Cloud (Supabase / Neon):
#   DATABASE_URL="postgresql://<user>:<password>@<host>.supabase.com:5432/postgres?sslmode=require"
#
# Local Docker (dev only):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gateway_db"
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST_IP>:5432/gateway_db"

# ── AI Service ────────────────────────────────────────────────────────────────
# The full URL of the ai-service /v1/chat/stream endpoint.
#
# CRITICAL for intranet deployments: this must be the real intranet IP of the
# machine running the ai-service process — NOT localhost. If the gateway and
# ai-service run on different servers, using localhost will cause a connection
# refused error because the gateway will try to call itself.
#
# Intranet (different machines):
#   AI_SERVICE_URL="http://<AI_SERVICE_HOST_IP>:8000/v1/chat/stream"
#
# Same machine (both services on one server):
#   AI_SERVICE_URL="http://localhost:8000/v1/chat/stream"
AI_SERVICE_URL="http://<AI_SERVICE_HOST_IP>:8000/v1/chat/stream"

# ── Public Gateway URL (optional) ─────────────────────────────────────────────
# The publicly reachable base URL of this gateway service.
# Used by the widget-client index.html dev harness and any server-side
# self-referential links. Not required for the gateway itself to function.
#
# Intranet:
#   NEXT_PUBLIC_GATEWAY_URL="http://<GATEWAY_HOST_IP>:3000"
NEXT_PUBLIC_GATEWAY_URL="http://<GATEWAY_HOST_IP>:3000"

# ── AI Memory ─────────────────────────────────────────────────────────────────
# Optional. Controls whether the AI service receives conversation history so
# it remembers prior turns within the same session (prevents "amnesia").
#
# true  — last 5 conversation turns are fetched from Postgres and injected as
#          context_history in the Contract B POST body sent to the ai-service.
# false — context_history is always an empty array. The AI treats every request
#          as a fresh conversation (lower token usage, stateless behaviour).
#
# IMPORTANT: this flag controls ONLY the Contract B payload. It does NOT affect
# the GET /api/chat/history endpoints — those always read from the database so
# the UI sidebar continues to show past sessions regardless of this setting.
#
# Recommended: true for production, false for isolated integration tests.
ENABLE_AI_MEMORY=true

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRE_AUTH controls whether POST /api/chat requests must carry a valid JWT
# Bearer token. Defaults to true (enforced) when not set.
#
# true  (production default): Authorization: Bearer <token> header is required.
#        The userId is extracted from the verified JWT — the body-supplied userId
#        is NOT trusted. Requires JWT_SECRET to be set.
# false (dev / bypass mode) : No token is required. The userId in the JSON
#        request body is trusted directly. Set this only for local development or
#        curl-based smoke testing. NEVER use false in production.
#
REQUIRE_AUTH=true

# JWT_SECRET — HS256 HMAC signing secret used to verify incoming JWTs.
# Required when REQUIRE_AUTH=true. Must be a sufficiently random string
# (32+ characters). Keep this value secret — never commit it.
#
# Generate a suitable secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
JWT_SECRET="<your-32-char-random-secret>"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to make cross-origin requests to this
# gateway. Only origins in this list will receive the correct
# Access-Control-Allow-Origin response header.
#
# When this variable is empty or unset, the gateway falls back to the wildcard
# "*" — convenient for local dev but unsafe for production.
#
# Example (development):
#   ALLOWED_ORIGINS="http://localhost:5173"
#
# Example (production — widget hosted on a different domain):
#   ALLOWED_ORIGINS="https://widget.example.com,https://intranet.corp.local"
#
ALLOWED_ORIGINS="<comma-separated-origins>"
