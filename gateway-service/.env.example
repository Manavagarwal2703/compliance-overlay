# gateway-service/.env.example
# ─────────────────────────────────────────────────────────────────────────────
# SAFE TO COMMIT — contains no real secrets. Copy this file to .env and fill
# in the actual values for your environment. The .env file is gitignored.
#
#   cp .env.example .env    (Linux / macOS)
#   copy .env.example .env  (Windows PowerShell)
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string for Prisma.
#
# On-Premise (Enterprise Intranet):
#   Replace <DB_HOST_IP> with the actual intranet IP of your PostgreSQL server.
#   DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST_IP>:5432/gateway_db"
#
# Cloud (Supabase / Neon):
#   DATABASE_URL="postgresql://<user>:<password>@<host>.supabase.com:5432/postgres?sslmode=require"
#
# Local Docker (dev only):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gateway_db"
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST_IP>:5432/gateway_db"

# ── AI Service ────────────────────────────────────────────────────────────────
# The full URL of the ai-service /v1/chat/stream endpoint.
#
# CRITICAL for intranet deployments: this must be the real intranet IP of the
# machine running the ai-service process — NOT localhost. If the gateway and
# ai-service run on different servers, using localhost will cause a connection
# refused error because the gateway will try to call itself.
#
# Intranet (different machines):
#   AI_SERVICE_URL="http://<AI_SERVICE_HOST_IP>:8000/v1/chat/stream"
#
# Same machine (both services on one server):
#   AI_SERVICE_URL="http://localhost:8000/v1/chat/stream"
AI_SERVICE_URL="http://<AI_SERVICE_HOST_IP>:8000/v1/chat/stream"
