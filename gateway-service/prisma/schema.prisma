// Prisma schema for gateway-service (Prisma 7+)
// Connection URL lives in prisma.config.ts, NOT here.
//
// Run: npx prisma format
//      npx prisma generate
//      npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id        String    @id
  userId    String
  role      String
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@index([userId])
}

model Message {
  id        String   @id
  sessionId String
  role      String
  content   String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}
